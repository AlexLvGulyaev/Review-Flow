# PostgreSQL
POSTGRES_DB=reviewflow
POSTGRES_USER=reviewflow
POSTGRES_PASSWORD=reviewflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Backend (SQLAlchemy URL)
DATABASE_URL=postgresql+psycopg2://reviewflow:reviewflow@postgres:5432/reviewflow

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8700

# Frontend → Backend
VITE_API_URL=http://localhost:8700

# OpenAI (optional — empty = use DB-selected provider with fallback to mock)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ProxyAPI OpenAI-compatible
PROXYAPI_KEY=
PROXYAPI_BASE_URL=https://api.proxyapi.ru/openai/v1

# GigaChat (OAuth via GIGACHAT_AUTH_KEY or CLIENT_ID + CLIENT_SECRET)
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-Max
GIGACHAT_MAX_TOKENS=500

# Phrase matching threshold (0-100, rapidfuzz scale)
PHRASE_MATCH_THRESHOLD=55
